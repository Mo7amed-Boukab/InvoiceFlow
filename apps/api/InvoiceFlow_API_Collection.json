		{
			"name": "Document Generation",
			"item": [
				{
					"name": "Generate Invoice Document",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.pdfUrl) {",
									"    pm.collectionVariables.set(\"pdfUrl\", jsonData.pdfUrl);",
									"    console.log('PDF URL:', jsonData.pdfUrl);",
									"}",
									"if (jsonData.googleDocGeneratedId) {",
									"    pm.collectionVariables.set(\"generatedDocId\", jsonData.googleDocGeneratedId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/invoices/{{invoiceId}}/generate",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"invoices",
								"{{invoiceId}}",
								"generate"
							]
						},
						"description": "Triggers the full generation pipeline:\n1. Copies the Google Doc template\n2. Replaces all {{placeholders}} with real invoice and client data\n3. Returns the invoice with googleDocGeneratedId and pdfUrl populated.\n\nRequirements:\n- User must have Google account connected (GET /auth/google first)\n- Invoice must have a templateId assigned\n- Template variables should be mapped via POST /templates/:id/variables/mapping"
					},
					"response": []
				}
			]
		}
